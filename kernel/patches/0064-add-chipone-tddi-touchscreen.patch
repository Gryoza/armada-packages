+#undef RAWDATA_TEST_DATA_FILENAME
+#undef NOISE_TEST_DATA_FILENAME
+#undef OPEN_TEST_DATA_FILENAME
+#undef SHORT_TEST_DATA_FILENAME
+#undef COMP_CAP_TEST_DATA_FILENAME
