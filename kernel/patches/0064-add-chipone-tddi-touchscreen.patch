+int disable_fw_monitor_mode(struct cts_device *cts_dev)
+{
+    int ret;
+    u8 value;
+
+    ret = cts_fw_reg_readb(cts_dev, 0x8000 + 344, &value);
+    if (ret)
+        return ret;
+
+    if (value & BIT(0))
+        return cts_fw_reg_writeb(cts_dev, 0x8000 + 344, value & (~BIT(0)));
+
+    return 0;
+}
