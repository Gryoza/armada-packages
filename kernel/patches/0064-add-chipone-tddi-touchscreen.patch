+void dump_spi(const char *prefix, u8 *data, size_t datalen)
+{
+    u8 str[1024];
+    int offset = 0;
+    int i;
+
+    offset += snprintf(str + offset, sizeof(str) - offset, "%s", prefix);
+    for (i = 0; i < datalen; i++) {
+        offset += snprintf(str + offset, sizeof(str) - offset, " %02x", data[i]);
+    }
+    cts_err("%s", str);
