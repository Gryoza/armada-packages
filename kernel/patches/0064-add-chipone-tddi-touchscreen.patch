+        return (ssize_t) 0;
+    }
+
+#ifdef CONFIG_CTS_I2C_HOST
+	path = ts_mmi_kobject_get_path(&data->i2c_client->dev.kobj, GFP_KERNEL);
+#else
+	path = ts_mmi_kobject_get_path(&data->spi_client->dev.kobj, GFP_KERNEL);
+#endif
+    blen = scnprintf(buf, PAGE_SIZE, "%s", path ? path : "na");
+    kfree(path);
+    return blen;
+}
