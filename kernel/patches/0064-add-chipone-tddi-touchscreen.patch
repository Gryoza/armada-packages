+    if (limit.open_item) {
+        seq_printf(m, "Open     : %s\n", open_test_result ? "Failed" : "Pass");
+    }
+    if (limit.short_item) {
+        seq_printf(m, "Short    : %s\n", short_test_result ? "Failed" : "Pass");
+    }
+    if (limit.comp_cap_item) {
+        seq_printf(m, "Comp-Cap : %s\n", comp_cap_test_result ? "Failed" : "Pass");
+    }
+
+    return 0;
+
