diff --git a/drivers/input/touchscreen/Kconfig b/drivers/input/touchscreen/Kconfig
index 63eb5a579..64b2c3bbe 100644
--- a/drivers/input/touchscreen/Kconfig
+++ b/drivers/input/touchscreen/Kconfig
@@ -14,6 +14,16 @@ if INPUT_TOUCHSCREEN
 
 source "drivers/input/touchscreen/synaptics_dsx/Kconfig"
 
+config TOUCHSCREEN_CHIPONE_TDDI
+	tristate "ChipOne ICNL9922C TDDI touchscreen"
+	depends on I2C
+	help
+	  Say Y here to enable support for the ChipOne ICNL9922C TDDI touch
+	  controller, as found on the KONKR Pocket FIT (Qualcomm SM8650).
+
+	  To compile this driver as a module, choose M here: the module will
+	  be called chipone_tddi.
+
 config TOUCHSCREEN_88PM860X
 	tristate "Marvell 88PM860x touchscreen"
 	depends on MFD_88PM860X
diff --git a/drivers/input/touchscreen/Makefile b/drivers/input/touchscreen/Makefile
index d44eab14d..281e1c4f6 100644
--- a/drivers/input/touchscreen/Makefile
+++ b/drivers/input/touchscreen/Makefile
@@ -9,6 +9,7 @@ wm97xx-ts-y := wm97xx-core.o
 goodix_ts-y := goodix.o goodix_fwupload.o
 
 obj-$(CONFIG_TOUCHSCREEN_SYNAPTICS_DSX)	+= synaptics_dsx/
+obj-$(CONFIG_TOUCHSCREEN_CHIPONE_TDDI)	+= chipone_tddi/
 obj-$(CONFIG_TOUCHSCREEN_88PM860X)	+= 88pm860x-ts.o
 obj-$(CONFIG_TOUCHSCREEN_AD7877)	+= ad7877.o
 obj-$(CONFIG_TOUCHSCREEN_AD7879)	+= ad7879.o
diff --git a/drivers/input/touchscreen/chipone_tddi/Makefile b/drivers/input/touchscreen/chipone_tddi/Makefile
new file mode 100644
index 000000000..e7962d348
--- /dev/null
+++ b/drivers/input/touchscreen/chipone_tddi/Makefile
@@ -0,0 +1,9 @@
+# SPDX-License-Identifier: GPL-2.0
+obj-$(CONFIG_TOUCHSCREEN_CHIPONE_TDDI) += chipone_tddi.o
+
+chipone_tddi-y := cts_driver.o cts_core.o cts_sfctrlv2.o cts_spi_flash.o \
+                  cts_firmware.o cts_test.o cts_tcs.o cts_platform.o \
+                  cts_tool.o cts_sysfs.o cts_strerror.o cts_oem.o
+
+ccflags-y += -DCONFIG_CTS_I2C_HOST -DCONFIG_CTS_IC_NAME_ICNL9922C -DCFG_CTS_WRAP_X
+ccflags-y += -I$(src)
