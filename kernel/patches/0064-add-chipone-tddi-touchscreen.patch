+#endif
+    if (cts_tcs_clr_gstr_ready_flag(cts_dev)) {
+        cts_err("Clear gesture ready flag failed");
+    }
+    if (ret < 0) {
+        cts_err("Get gesture info failed: ret=%d", ret);
