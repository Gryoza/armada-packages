+    ret = request_threaded_irq(pdata->irq, NULL, cts_plat_irq_handler,
+            IRQF_TRIGGER_FALLING | IRQF_ONESHOT, CFG_CTS_DRIVER_NAME, pdata);
+#else /* CONFIG_GENERIC_HARDIRQS */
