+#ifdef CTS_MTK_GET_PANEL
+char panel_name[50] = { 0 };
+
+static int cts_get_panel(void)
+{
+    int ret = -1;
+
+    cts_info("Enter cts_get_panel");
+    if (saved_command_line) {
+        char *sub;
+        char key_prefix[] = "mipi_mot_vid_";
+        char ic_prefix[] = "icnl";
