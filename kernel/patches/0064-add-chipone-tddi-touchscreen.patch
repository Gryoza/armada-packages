+int parse_arg(const char *buf, size_t count)
+{
+    char *p;
+
+    memcpy(cmdline_param, buf, min((size_t)MAX_ARG_LENGTH, count));
+    cmdline_param[count] = '\0';
+
+    argc = 0;
+    p = strim(cmdline_param);
+    if (p == NULL || p[0] == '\0')
+        return 0;
+
+    while (p && p[0] != '\0' && argc < MAX_ARG_NUM)
+        argv[argc++] = strsep(&p, " ,");
+
+    return argc;
+}
