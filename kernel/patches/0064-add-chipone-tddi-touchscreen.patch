+static void dump_tsdata_to_seq_file(struct seq_file *m,
+        const u16 *data, int rows, int cols, int hw_cols)
+{
+    int r;
+
+    for (r = 0; r < rows; r++) {
+        char linebuf[256];
+        int len;
+
+        len = dump_tsdata_row_to_buffer(linebuf, sizeof(linebuf),
+            data, cols, NULL, "\n", ',');
+        seq_puts(m, linebuf);
+
+        data += hw_cols;
+    }
+}
